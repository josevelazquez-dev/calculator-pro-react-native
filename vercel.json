{
  "version": 2,
  "public": true,
  "buildCommand": "npx expo export --platform web --output-dir dist",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/((?!_expo/|assets/|icons/|screenshots/|sw.js|offline.html|manifest.json|favicon.ico|apple-touch-icon).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/sw.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" },
        { "key": "Service-Worker-Allowed", "value": "/" }
      ]
    },
    {
      "source": "/(.+\\.(js|css|png|jpg|ico|svg))",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
